---
import BaseLayout from '../layouts/BaseLayout.astro';
import PricingTable from '../components/PricingTable.astro';
import CTA from '../components/CTA.astro';

// Product schema — gives Google enough structure to potentially
// surface pricing in SERPs (rich snippet eligibility) and feeds
// merchant-listing-style results. AggregateOffer is the right shape
// here because we have multiple tiers; if you ever want individual
// tier rich results, split this into one Product per tier.
// Reference:
// https://developers.google.com/search/docs/appearance/structured-data/product
const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'Perspectiv Network Monitoring',
  description:
    'Self-hosted network monitoring software with tier-based annual pricing. Every plan includes SNMP, NetFlow, syslog, agents, NetPath, alerting, and reporting.',
  brand: {
    '@type': 'Brand',
    name: 'Perspectiv',
  },
  category: 'Network Monitoring Software',
  offers: {
    '@type': 'AggregateOffer',
    priceCurrency: 'USD',
    lowPrice: '399',
    highPrice: '2499',
    offerCount: '4',
    availability: 'https://schema.org/InStock',
    url: 'https://perspectiv.net/pricing',
  },
};
---

<BaseLayout
  title="Pricing"
  description="Flat tier-based annual pricing for Perspectiv network monitoring. From $399/mo for 100 devices, never per-node. ICMP-only devices always unlimited."
  structuredData={productSchema}
>
  <!-- ── Header ─────────────────────────────────────────────────────── -->
  <section class="bg-gradient-to-b from-slate-50 to-white py-20 sm:py-24">
    <div class="container-wide text-center">
      <p class="section-eyebrow">Pricing</p>
      <h1 class="text-4xl font-bold tracking-tight text-slate-900 sm:text-5xl">
        Everything included. One product. Every tier.
      </h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-600">
        No module-licensing math. No per-feature upsells. No surprise true-ups
        when you add devices. Pick the size that fits your environment, not
        the features you're allowed to use.
      </p>
    </div>
  </section>

  <!-- ── Tier table ─────────────────────────────────────────────────── -->
  <section class="bg-white pb-20">
    <div class="container-wide">
      <PricingTable />

      <div class="mx-auto mt-10 max-w-3xl rounded-xl bg-slate-50 p-6 text-center">
        <p class="text-sm text-slate-700">
          <span class="font-semibold">Single payment, no auto-renewal.</span> You pay once for the term you pick —
          12 months at 15% off, or 24 months at 25% off.
          When the term ends, your license expires and you choose whether to renew. No surprise charges, ever.
        </p>
        <p class="mt-3 text-sm text-slate-700">
          Multi-site, multi-tenant, government pricing, and 3+ year terms — <a href="/contact?topic=scale" class="font-medium">talk to us</a> for the Scale tier.
        </p>
      </div>
    </div>
  </section>

  <!-- ── ICMP-only callout ──────────────────────────────────────────── -->
  <section class="bg-slate-50 py-20">
    <div class="container-wide">
      <div class="mx-auto max-w-3xl text-center">
        <p class="section-eyebrow">No surprise device counts</p>
        <h2 class="text-3xl font-bold tracking-tight text-slate-900">
          Only pay for full monitoring
        </h2>
        <p class="mt-4 text-lg text-slate-600">
          Every fully-monitored device — SNMP, WMI, agent — counts toward
          your plan's cap.{' '}
          <span class="font-semibold text-slate-900">
            ICMP-only devices are free.
          </span>
        </p>
        <p class="mt-3 text-base text-slate-600">
          Discovered 800 devices on your subnet scan? Watch them all. Promote
          the ones that actually matter to full monitoring when you're ready.
        </p>
      </div>
    </div>
  </section>

  <!-- ── What's included ────────────────────────────────────────────── -->
  <section class="bg-white py-20">
    <div class="container-wide">
      <div class="mx-auto max-w-2xl text-center">
        <p class="section-eyebrow">Every plan, every feature</p>
        <h2 class="text-3xl font-bold tracking-tight text-slate-900">
          Choose your tier based on devices, not features
        </h2>
      </div>

      <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-8 md:grid-cols-2">
        <div>
          <h3 class="text-base font-semibold text-slate-900">Network &amp; infrastructure</h3>
          <ul class="mt-3 space-y-2 text-sm text-slate-600">
            <li>SNMP v1, v2c, v3 monitoring</li>
            <li>Server, app, and service monitoring (agent-based)</li>
            <li>NetFlow analysis — top talkers, conversation flows</li>
            <li>Configuration backup &amp; change tracking</li>
            <li>IP address management (IPAM)</li>
            <li>Topology / network maps via LLDP/CDP</li>
            <li>Service checks — TCP, HTTP/S, DNS, ICMP, traceroute</li>
          </ul>
        </div>

        <div>
          <h3 class="text-base font-semibold text-slate-900">Alerting &amp; response</h3>
          <ul class="mt-3 space-y-2 text-sm text-slate-600">
            <li>Multi-channel alerting — email, webhooks, escalation paths</li>
            <li>Per-rule cooldowns and dedup</li>
            <li>Acknowledge &amp; comment workflow for shift hand-off</li>
            <li>SNMP trap &amp; syslog ingestion + correlation</li>
          </ul>
        </div>

        <div>
          <h3 class="text-base font-semibold text-slate-900">Reporting &amp; dashboards</h3>
          <ul class="mt-3 space-y-2 text-sm text-slate-600">
            <li>Custom dashboards — drag-to-place widgets</li>
            <li>Pre-built availability, performance, lifecycle, backup reports</li>
            <li>Scheduled email reports — daily, weekly, monthly</li>
            <li>14d raw / 1y hourly / 5y daily retention on every plan</li>
          </ul>
        </div>

        <div>
          <h3 class="text-base font-semibold text-slate-900">Security &amp; operations</h3>
          <ul class="mt-3 space-y-2 text-sm text-slate-600">
            <li>SSO — SAML, OIDC (Professional and up)</li>
            <li>Role-based access control + audit log</li>
            <li>System backup &amp; restore — full config in one click</li>
            <li>Built-in SSH client to monitored devices</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ── SolarWinds comparison ──────────────────────────────────────── -->
  <section class="bg-slate-900 py-20 text-slate-100">
    <div class="container-wide">
      <div class="mx-auto max-w-2xl text-center">
        <p class="text-sm font-semibold uppercase tracking-wider text-accent-400">
          The honest comparison
        </p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-white sm:text-4xl">
          How we compare to SolarWinds
        </h2>
      </div>

      <div class="mx-auto mt-12 max-w-4xl overflow-hidden rounded-xl border border-slate-700">
        <table class="w-full text-left text-sm">
          <thead class="bg-slate-800 text-xs uppercase tracking-wider text-slate-400">
            <tr>
              <th class="px-6 py-3">Capability</th>
              <th class="px-6 py-3">SolarWinds</th>
              <th class="px-6 py-3">Perspectiv</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-700">
            {[
              ['Network performance', 'NPM module',  'Every plan'],
              ['Server & app monitoring', 'SAM module', 'Every plan'],
              ['NetFlow analysis', 'NTA module', 'Every plan'],
              ['Configuration management', 'NCM module', 'Every plan'],
              ['IP address management', 'IPAM module', 'Every plan'],
              ['Log management / syslog', 'LEM module', 'Every plan'],
              ['Pricing model', 'Per-node, per-module', 'Flat rate per tier'],
              ['Hosting', 'Windows server (heavy)', 'Linux container (~16 GB RAM)'],
            ].map(([cap, sw, p]) => (
              <tr>
                <td class="px-6 py-4 font-medium text-white">{cap}</td>
                <td class="px-6 py-4 text-slate-400">{sw}</td>
                <td class="px-6 py-4 font-semibold text-accent-400">{p}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <p class="mx-auto mt-6 max-w-2xl text-center text-xs text-slate-500">
        Comparison reflects publicly-listed SolarWinds product configuration
        as of 2025. Module names and pricing tiers may vary by SolarWinds
        edition.
      </p>
    </div>
  </section>

  <CTA />

  <!-- ── Buy modal — shown when a Buy button on a tier card is clicked ─── -->
  <div
    id="buy-modal"
    class="fixed inset-0 z-50 hidden items-center justify-center bg-slate-900/50 p-4"
    role="dialog"
    aria-modal="true"
    aria-labelledby="buy-modal-title"
  >
    <div class="w-full max-w-md rounded-xl bg-white p-6 shadow-xl">
      <div class="flex items-start justify-between">
        <div>
          <h2 id="buy-modal-title" class="text-xl font-bold text-slate-900">
            Buy <span id="buy-modal-tier">Starter</span>
          </h2>
          <p id="buy-modal-summary" class="mt-1 text-sm text-slate-600">
            1-year license &middot; <span id="buy-modal-price">$4,070</span>
          </p>
        </div>
        <button
          type="button"
          id="buy-modal-close"
          class="rounded-md p-1 text-slate-400 hover:bg-slate-100 hover:text-slate-600"
          aria-label="Close"
        >
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>

      <form id="buy-modal-form" class="mt-5 space-y-4">
        <div>
          <label for="buy-instance-id" class="block text-sm font-medium text-slate-700">
            Instance ID <span class="text-rose-600">*</span>
          </label>
          <input
            type="text"
            id="buy-instance-id"
            name="instance_id"
            required
            placeholder="e.g. 47d4af9b-38e7-40fb-a3c2-532b37fc9d25"
            pattern="^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
            class="mt-1 block w-full rounded-lg border border-slate-300 px-3 py-2 text-sm font-mono shadow-sm focus:border-brand-600 focus:outline-none focus:ring-2 focus:ring-brand-600"
          />
          <p class="mt-1 text-xs text-slate-500">
            Find this in your Perspectiv install at <strong>Settings &rarr; License &rarr; Instance ID</strong>.
            Don't have one yet? <a href="/download" class="font-medium">Install Perspectiv free</a> first to get your Instance ID.
          </p>
        </div>

        <div>
          <label for="buy-email" class="block text-sm font-medium text-slate-700">
            Email <span class="text-rose-600">*</span>
          </label>
          <input
            type="email"
            id="buy-email"
            name="customer_email"
            required
            autocomplete="email"
            placeholder="you@company.com"
            class="mt-1 block w-full rounded-lg border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-brand-600 focus:outline-none focus:ring-2 focus:ring-brand-600"
          />
          <p class="mt-1 text-xs text-slate-500">
            We'll send your license key here after payment.
          </p>
        </div>

        <div id="buy-modal-error" class="hidden rounded-lg border border-rose-200 bg-rose-50 p-3 text-sm text-rose-800"></div>

        <div class="flex flex-col gap-3 pt-2 sm:flex-row sm:items-center sm:justify-end">
          <button
            type="button"
            id="buy-modal-cancel"
            class="btn-secondary justify-center text-sm"
          >
            Cancel
          </button>
          <button
            type="submit"
            id="buy-modal-submit"
            class="btn-primary justify-center text-sm"
          >
            Continue to payment
          </button>
        </div>
      </form>

      <p class="mt-4 text-center text-xs text-slate-500">
        Single payment. No auto-renewal. Secure checkout via Stripe.
      </p>
    </div>
  </div>

  <script is:inline>
    (() => {
      const modal      = document.getElementById('buy-modal');
      const modalTier  = document.getElementById('buy-modal-tier');
      const modalPrice = document.getElementById('buy-modal-price');
      const modalSum   = document.getElementById('buy-modal-summary');
      const form       = document.getElementById('buy-modal-form');
      const errorBox   = document.getElementById('buy-modal-error');
      const submitBtn  = document.getElementById('buy-modal-submit');
      const closeBtn   = document.getElementById('buy-modal-close');
      const cancelBtn  = document.getElementById('buy-modal-cancel');
      const idField    = document.getElementById('buy-instance-id');
      const emailField = document.getElementById('buy-email');

      let currentPriceId = '';

      function openModal(tier, term, priceId, priceDisplay) {
        currentPriceId = priceId;
        modalTier.textContent  = tier;
        modalPrice.textContent = priceDisplay.split(' / ')[0];
        modalSum.firstChild.textContent =
          (term === '1y' ? '1-year license · ' : '2-year license · save 25% · ');
        errorBox.classList.add('hidden');
        errorBox.textContent = '';
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        // Focus the first input so keyboard users land in the right place
        setTimeout(() => idField.focus(), 50);
      }

      function closeModal() {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
        form.reset();
      }

      // Wire up every Buy button on the page
      document.querySelectorAll('.buy-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          const tier         = btn.dataset.tier;
          const term         = btn.dataset.term;
          const priceId      = btn.dataset.priceId;
          const priceDisplay = btn.dataset.priceDisplay;
          if (!priceId || !priceId.startsWith('price_')) {
            // Disabled state — placeholder Price ID, button shouldn't actually work
            return;
          }
          openModal(tier, term, priceId, priceDisplay);
        });
      });

      closeBtn?.addEventListener('click', closeModal);
      cancelBtn?.addEventListener('click', closeModal);
      // Click outside the inner panel to close
      modal?.addEventListener('click', (e) => {
        if (e.target === modal) closeModal();
      });
      // ESC key to close
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !modal.classList.contains('hidden')) closeModal();
      });

      // Form submit — POST to /api/checkout-session, redirect to Stripe URL
      form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        errorBox.classList.add('hidden');
        submitBtn.disabled = true;
        submitBtn.textContent = 'Working…';

        const instanceId = idField.value.trim();
        const email      = emailField.value.trim();
        try {
          const res = await fetch('/api/checkout-session', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              price_id:       currentPriceId,
              instance_id:    instanceId,
              customer_email: email,
            }),
          });
          if (!res.ok) {
            const data = await res.json().catch(() => ({}));
            throw new Error(data.error || 'Could not create checkout session.');
          }
          const data = await res.json();
          if (!data.url) throw new Error('Checkout session did not return a URL.');
          // Hand off the browser to Stripe
          window.location.href = data.url;
        } catch (err) {
          errorBox.textContent = err.message || 'Something went wrong. Try again.';
          errorBox.classList.remove('hidden');
          submitBtn.disabled = false;
          submitBtn.textContent = 'Continue to payment';
        }
      });
    })();
  </script>
</BaseLayout>
