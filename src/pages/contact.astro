---
import BaseLayout from '../layouts/BaseLayout.astro';

// This page is statically rendered, so query params (?topic=, ?status=)
// can't be read at build time. The inline script at the bottom of the
// page swaps visibility and pre-selects the topic at runtime instead.

const topicOptions: Array<{ value: string; label: string }> = [
  { value: 'general', label: 'General inquiry' },
  { value: 'scale',   label: 'Scale tier pricing (1,000+ devices, multi-site)' },
  { value: 'partner', label: 'Charter Program (design partner application)' },
  { value: 'support', label: 'Support / installation help' },
  { value: 'other',   label: 'Other' },
];

const deviceRanges = [
  'Under 50 devices',
  '50 – 250 devices',
  '250 – 1,000 devices',
  '1,000 – 2,500 devices',
  '2,500+ devices (Scale tier)',
  'Not sure yet',
];
---

<BaseLayout
  title="Talk to sales"
  description="Get in touch with the Perspectiv team. Pricing, Scale-tier inquiries, design-partner applications, and migration help."
>
  <section class="bg-gradient-to-b from-slate-50 to-white py-16 sm:py-20">
    <div class="container-prose">
      <div class="text-center">
        <p class="section-eyebrow">Talk to sales</p>
        <h1 class="text-4xl font-bold tracking-tight text-slate-900 sm:text-5xl">
          Tell us about your network
        </h1>
        <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-600">
          We're a small team and replies come from a human. Most inquiries hear
          back within one US business day.
        </p>
      </div>

      <!-- Success state — hidden by default, revealed when ?status=sent. -->
      <div
        id="contact-success"
        role="status"
        class="mx-auto mt-10 hidden max-w-xl rounded-xl border border-emerald-200 bg-emerald-50 p-6 text-center"
      >
        <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-emerald-100">
          <svg class="h-6 w-6 text-emerald-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
        </div>
        <h2 class="mt-4 text-xl font-semibold text-emerald-900">Thanks — we got it.</h2>
        <p class="mt-2 text-sm text-emerald-800">
          We'll reply from <strong>sales@perspectiv.net</strong> within one US
          business day. If you don't see a reply, check your spam folder for
          mail from that address.
        </p>
        <div class="mt-6">
          <a href="/" class="btn-secondary text-sm">Back to home</a>
        </div>
      </div>

      <form
        id="contact-form"
        method="POST"
        action="/api/contact"
        class="mx-auto mt-10 max-w-xl space-y-5 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8"
      >
        <!-- Error state — hidden by default, revealed when ?status=error. -->
        <div
          id="contact-error"
          role="alert"
          class="hidden rounded-lg border border-rose-200 bg-rose-50 p-4 text-sm text-rose-800"
        >
          Something went wrong sending your message. Please try again, or
          email us directly at{' '}
          <a href="mailto:sales@perspectiv.net" class="font-semibold underline">
            sales@perspectiv.net
          </a>.
        </div>

        <!-- Honeypot — humans don't see this; bots fill it. Worker rejects any submission with a non-empty value. -->
        <div class="hidden" aria-hidden="true">
          <label>
            Website
            <input type="text" name="website" tabindex="-1" autocomplete="off" />
          </label>
        </div>

        <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
          <div>
            <label for="name" class="block text-sm font-medium text-slate-700">
              Name <span class="text-rose-600">*</span>
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              autocomplete="name"
              class="mt-1 block w-full rounded-lg border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-brand-600 focus:outline-none focus:ring-2 focus:ring-brand-600"
            />
          </div>

          <div>
            <label for="company" class="block text-sm font-medium text-slate-700">
              Company <span class="text-rose-600">*</span>
            </label>
            <input
              type="text"
              id="company"
              name="company"
              required
              autocomplete="organization"
              class="mt-1 block w-full rounded-lg border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-brand-600 focus:outline-none focus:ring-2 focus:ring-brand-600"
            />
          </div>
        </div>

        <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
          <div>
            <label for="email" class="block text-sm font-medium text-slate-700">
              Work email <span class="text-rose-600">*</span>
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              autocomplete="email"
              class="mt-1 block w-full rounded-lg border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-brand-600 focus:outline-none focus:ring-2 focus:ring-brand-600"
            />
          </div>

          <div>
            <label for="phone" class="block text-sm font-medium text-slate-700">
              Phone <span class="text-slate-400">(optional)</span>
            </label>
            <input
              type="tel"
              id="phone"
              name="phone"
              autocomplete="tel"
              class="mt-1 block w-full rounded-lg border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-brand-600 focus:outline-none focus:ring-2 focus:ring-brand-600"
            />
          </div>
        </div>

        <div>
          <label for="topic" class="block text-sm font-medium text-slate-700">
            What's this about? <span class="text-rose-600">*</span>
          </label>
          <select
            id="topic"
            name="topic"
            required
            class="mt-1 block w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-brand-600 focus:outline-none focus:ring-2 focus:ring-brand-600"
          >
            {topicOptions.map((opt) => (
              <option value={opt.value}>{opt.label}</option>
            ))}
          </select>
        </div>

        <div>
          <label for="devices" class="block text-sm font-medium text-slate-700">
            Approximate device count <span class="text-slate-400">(optional)</span>
          </label>
          <select
            id="devices"
            name="devices"
            class="mt-1 block w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-brand-600 focus:outline-none focus:ring-2 focus:ring-brand-600"
          >
            <option value="">Select a range...</option>
            {deviceRanges.map((range) => (
              <option value={range}>{range}</option>
            ))}
          </select>
        </div>

        <div>
          <label for="message" class="block text-sm font-medium text-slate-700">
            Tell us a bit more <span class="text-rose-600">*</span>
          </label>
          <textarea
            id="message"
            name="message"
            rows="5"
            required
            minlength="10"
            maxlength="5000"
            placeholder="What you're trying to monitor, what you're moving from, timeline, anything else useful."
            class="mt-1 block w-full rounded-lg border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-brand-600 focus:outline-none focus:ring-2 focus:ring-brand-600"
          ></textarea>
        </div>

        <div class="flex flex-col gap-3 pt-2 sm:flex-row sm:items-center sm:justify-between">
          <p class="text-xs text-slate-500">
            We use your details only to reply. No marketing list, no third-party sharing.
          </p>
          <button type="submit" class="btn-primary justify-center text-sm">
            Send message
          </button>
        </div>
      </form>

      <p class="mt-6 text-center text-sm text-slate-500">
        Prefer email? Reach us at{' '}
        <a href="mailto:sales@perspectiv.net" class="font-medium">sales@perspectiv.net</a>.
      </p>
    </div>
  </section>

  <script is:inline>
    // Read query params at runtime (the page is statically rendered, so this
    // is the only place we know what ?topic= and ?status= are).
    (() => {
      const params = new URLSearchParams(window.location.search);
      const status = params.get('status');
      const topic  = params.get('topic');

      if (status === 'sent') {
        document.getElementById('contact-success')?.classList.remove('hidden');
        document.getElementById('contact-form')?.classList.add('hidden');
      } else if (status === 'error') {
        document.getElementById('contact-error')?.classList.remove('hidden');
      }

      if (topic) {
        const select = document.getElementById('topic');
        const allowed = ['general', 'scale', 'partner', 'support', 'other'];
        if (select instanceof HTMLSelectElement && allowed.includes(topic)) {
          select.value = topic;
        }
      }
    })();
  </script>
</BaseLayout>
