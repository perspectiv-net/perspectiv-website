---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Stripe redirects here after a successful Checkout payment with
// ?session_id={CHECKOUT_SESSION_ID} appended. We don't actually need to
// hit Stripe's API to confirm — the webhook handler is the source of
// truth for "did this payment succeed and was a license issued?". This
// page is purely a customer-facing thank-you. Keeping it simple by
// design — no JS, no Stripe API call, just clear copy about what
// happens next.
---

<BaseLayout
  title="Thanks — your Perspectiv license is on its way"
  description="Your Perspectiv license key is being delivered to the email you provided at checkout."
>
  <section class="bg-gradient-to-b from-slate-50 to-white py-20 sm:py-24">
    <div class="container-prose">
      <div class="mx-auto max-w-2xl text-center">
        <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-emerald-100">
          <svg class="h-9 w-9 text-emerald-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
        </div>

        <h1 class="mt-6 text-4xl font-bold tracking-tight text-slate-900 sm:text-5xl">
          Thanks — payment received
        </h1>
        <p class="mx-auto mt-4 max-w-xl text-lg text-slate-600">
          Your Perspectiv license key is on its way to the email address you
          provided at checkout. Most customers see it arrive within seconds.
        </p>
      </div>

      <!-- ── What happens next ──────────────────────────────────────────── -->
      <div class="mx-auto mt-12 max-w-2xl rounded-2xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
        <h2 class="text-lg font-semibold text-slate-900">What happens next</h2>
        <ol class="mt-4 space-y-4 text-sm text-slate-700">
          <li class="flex gap-3">
            <span class="flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full bg-brand-100 text-xs font-bold text-brand-700">1</span>
            <span>
              <strong class="text-slate-900">Check your inbox</strong> for an email
              titled <em>Your Perspectiv license key</em>. If it doesn't show up
              within a couple of minutes, check spam — it'll be from
              <code class="rounded bg-slate-100 px-1 py-0.5 text-xs">sales@perspectiv.net</code>.
            </span>
          </li>
          <li class="flex gap-3">
            <span class="flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full bg-brand-100 text-xs font-bold text-brand-700">2</span>
            <span>
              <strong class="text-slate-900">Open your Perspectiv install</strong> and
              navigate to <strong>Settings &rarr; License</strong>.
            </span>
          </li>
          <li class="flex gap-3">
            <span class="flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full bg-brand-100 text-xs font-bold text-brand-700">3</span>
            <span>
              <strong class="text-slate-900">Paste the license key</strong> from the
              email into the <em>Activate License Key</em> field, then click
              <em>Activate</em>. Your status should switch to Active immediately.
            </span>
          </li>
        </ol>
      </div>

      <!-- ── Help / contact ─────────────────────────────────────────────── -->
      <div class="mx-auto mt-8 max-w-2xl text-center">
        <p class="text-sm text-slate-600">
          Anything not working? Reply directly to the license email or
          contact <a href="mailto:sales@perspectiv.net" class="font-medium">sales@perspectiv.net</a> —
          we read every reply personally.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:justify-center">
          <a href="/" class="btn-secondary text-sm">Back to home</a>
          <a href="/pricing" class="btn-secondary text-sm">View pricing</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
