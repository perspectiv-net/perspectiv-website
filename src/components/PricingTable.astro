---
// Pricing tier table — used on /pricing.
// Tier data centralized here so updates land in one place.

interface Tier {
  name: string;
  devices: string;
  oneYear: string;
  twoYear: string;
  highlight?: boolean;
}

// Pricing is one-time payment per term (NOT auto-renewing subscription).
// Customer pays once for 1 or 2 years; license expires at end of term;
// they re-purchase to continue.
//
// Discount math:
//   1-year: 15% off the monthly rate × 12  (e.g. $399 × 12 × 0.85 = $4,070)
//   2-year: 25% off the monthly rate × 24  (e.g. $399 × 24 × 0.75 = $7,182)
//
// Keep these in sync with the Stripe Products & Prices and docs/pricing.md.
// Each tier needs two One-off Stripe Prices: one with term_days=365 in
// metadata for the 1-year tier, one with term_days=730 for the 2-year tier.
const tiers: Tier[] = [
  { name: 'Starter',      devices: '100',    oneYear: '$4,070',  twoYear: '$7,182 / 2-yr'  },
  { name: 'Professional', devices: '250',    oneYear: '$9,170',  twoYear: '$16,182 / 2-yr', highlight: true },
  { name: 'Business',     devices: '500',    oneYear: '$16,310', twoYear: '$28,782 / 2-yr' },
  { name: 'Enterprise',   devices: '1,000',  oneYear: '$28,550', twoYear: '$50,382 / 2-yr' },
  { name: 'Scale',        devices: '1,000+', oneYear: 'custom',  twoYear: 'multi-site, multi-tenant'  },
];
---

<div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-5">
  {
    tiers.map((tier) => (
      <div
        class={`relative rounded-2xl border p-6 ${
          tier.highlight
            ? 'border-brand-600 bg-brand-50 shadow-lg ring-1 ring-brand-600'
            : 'border-slate-200 bg-white'
        }`}
      >
        {tier.highlight && (
          <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-brand-600 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-white">
            Most popular
          </span>
        )}

        <h3 class="text-lg font-semibold text-slate-900">{tier.name}</h3>

        <div class="mt-4">
          <p class="text-3xl font-bold tracking-tight text-slate-900">{tier.oneYear}</p>
          <p class="mt-1 text-xs text-slate-500">
            {tier.name === 'Scale' ? '' : '1-year license'}
          </p>
        </div>

        <div class="mt-3 rounded-md bg-slate-50 px-3 py-2">
          <p class="text-sm font-semibold text-slate-900">{tier.twoYear}</p>
          <p class="text-xs text-slate-500">
            {tier.name === 'Scale' ? '' : '2-year license · save 25%'}
          </p>
        </div>

        <div class="mt-6 border-t border-slate-200 pt-4">
          <p class="text-sm text-slate-700">
            <span class="font-semibold">{tier.devices}</span>{' '}
            fully-monitored devices
          </p>
          <p class="mt-1 text-sm text-slate-500">
            Unlimited ICMP-only
          </p>
        </div>

        <div class="mt-6">
          {tier.name === 'Scale' ? (
            <a
              href="/contact?topic=scale"
              class={`block rounded-lg px-4 py-2 text-center text-sm font-semibold no-underline transition-colors ${
                tier.highlight
                  ? 'bg-brand-600 text-white hover:bg-brand-700'
                  : 'border border-slate-300 bg-white text-slate-700 hover:bg-slate-50'
              }`}
            >
              Contact sales
            </a>
          ) : (
            <a
              href="/download"
              class={`block rounded-lg px-4 py-2 text-center text-sm font-semibold no-underline transition-colors ${
                tier.highlight
                  ? 'bg-brand-600 text-white hover:bg-brand-700'
                  : 'border border-slate-300 bg-white text-slate-700 hover:bg-slate-50'
              }`}
            >
              Start free trial
            </a>
          )}
        </div>
      </div>
    ))
  }
</div>
