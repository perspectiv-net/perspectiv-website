---
// Reusable closing CTA — appears at the bottom of most pages.
// Drives toward the trial download.

interface Props {
  /** Optional override for the heading text. */
  heading?: string;
  /** Optional override for the body text. */
  body?: string;
}

const {
  heading = 'Ready to monitor your network without per-node billing?',
  body    = 'The 30-day trial activates on first boot. No credit card, no sales call required.',
} = Astro.props;
---

<section class="bg-brand-950 text-white">
  <div class="container-wide py-16 sm:py-20">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
        {heading}
      </h2>
      <p class="mt-4 text-lg text-brand-100">
        {body}
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row sm:gap-4">
        <a
          href="/download"
          class="inline-flex items-center gap-2 rounded-lg bg-accent-500 px-5 py-3 text-base font-semibold text-slate-900 no-underline transition-colors hover:bg-accent-400"
        >
          Start free trial
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a
          href="/contact"
          class="inline-flex items-center gap-2 rounded-lg border border-brand-700 px-5 py-3 text-base font-semibold text-white no-underline transition-colors hover:bg-brand-900"
        >
          Talk to sales
        </a>
      </div>
    </div>
  </div>
</section>
